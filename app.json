{
  "expo": {
    "name": "AutolibreAI",
    "slug": "mvp-react-native",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "autolibreai",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "com.ramiro.autolibreai",
      "supportsTablet": true
    },
    "android": {
      "package": "com.ramiro.autolibreai",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.BLUETOOTH",
        "android.permission.BLUETOOTH_ADMIN",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.BLUETOOTH_CONNECT",
        "android.permission.BLUETOOTH_SCAN",
        "android.permission.BLUETOOTH_ADVERTISE"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/Space_Grotesk/SpaceGrotesk-Light.ttf",
            "./assets/fonts/Space_Grotesk/SpaceGrotesk-Regular.ttf",
            "./assets/fonts/Space_Grotesk/SpaceGrotesk-Medium.ttf",
            "./assets/fonts/Space_Grotesk/SpaceGrotesk-SemiBold.ttf",
            "./assets/fonts/Space_Grotesk/SpaceGrotesk-Bold.ttf"
          ]
        }
      ],
      [
        "with-rn-bluetooth-classic",
        {
          "peripheralUsageDescription": "Necesitamos Bluetooth para buscar y conectar el escáner OBD.",
          "alwaysUsageDescription": "Usamos Bluetooth para mantener la conexión con el escáner cuando la app está activa.",
          "protocols": [
            "com.apple.m1"
          ]
        }
      ],
      "@clerk/expo",
      "expo-secure-store",
      [
        "@sentry/react-native/expo",
        {
          "url": "https://sentry.io/",
          "project": "sentry-pentapp-mvp-rn",
          "organization": "pentapp"
        }
      ],
      "@sentry/react-native"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "10b9df1d-fc0c-42af-a9b7-4649c7d12f38"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/10b9df1d-fc0c-42af-a9b7-4649c7d12f38"
    }
  }
}
